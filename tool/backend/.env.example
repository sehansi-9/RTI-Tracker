# allowed origins
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# postgres secrets
POSTGRES_HOST=localhost:5432

POSTGRES_USER=rti
POSTGRES_PASSWORD=rti
POSTGRES_DB=rti

# db bounded-retry
MAX_RETRIES=5
RETRY_DELAY=3  #in seconds

# asgardio secrets
ASGARDEO_ORG=<org_name>
CLIENT_ID=<client_id>
CLIENT_SECRET=<client_secret>

# github repository configuration
GITHUB_TOKEN=<personal_access_token>
GITHUB_REPO_NAME=<repository_name>
GITHUB_BRANCH=<branch_name>

# HTTP Connection Pool Configuration (Optional)
# Adjust based on your deployment resources and backend capacity
HTTP_POOL_SIZE=50
HTTP_POOL_SIZE_PER_HOST=40
HTTP_TIMEOUT_TOTAL=90

# Timeout configs
HTTP_TIMEOUT_CONNECT=30
HTTP_TIMEOUT_SOCK_CONNECT=30
HTTP_TIMEOUT_SOCK_READ=90
HTTP_TTL_DNS_CACHE=300